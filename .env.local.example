# ── Aura — copy to .env.local and fill in your values ────────────────────────

# WalletConnect / Reown Project ID  (required for wallet modal)
# Get one free at: https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chain profile — "testnet" uses Celo Sepolia, "mainnet" uses Celo
NEXT_PUBLIC_CHAIN_PROFILE=testnet

# App display name (shown in wallet modal)
NEXT_PUBLIC_APP_NAME=Aura

# ── Contract addresses (set after deploying AuraTip.sol) ─────────────────────
NEXT_PUBLIC_AURA_TIP_ADDRESS_TESTNET=
NEXT_PUBLIC_AURA_TIP_ADDRESS_MAINNET=
# MockUSDm address on Celo Sepolia testnet (output of contracts:deploy:testnet)
NEXT_PUBLIC_USDM_ADDRESS_TESTNET=

# ── AI Scout (optional — falls back to heuristic if unset) ───────────────────
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── CeloScan API key (needed for AI Scout + contract verification) ────────────
# Get one free at: https://celoscan.io/myapikey
NEXT_PUBLIC_CELOSCAN_API_KEY=

# ── RPC provider (Hardhat deploy + frontend fallback) ────────────────────────
# Free at: https://dashboard.alchemy.com → Create App → Chain: Celo
# Enable both "Celo Mainnet" and "Celo Sepolia" in the Networks tab
# URLs: https://celo-mainnet.g.alchemy.com/v2/{key} / https://celo-sepolia.g.alchemy.com/v2/{key}
ALCHEMY_API_KEY=

# ── Deployer wallet (server-side only — NEVER prefix with NEXT_PUBLIC_) ───────
# Private key of the wallet used to deploy contracts (funded with CELO for gas)
DEPLOYER_PRIVATE_KEY=
