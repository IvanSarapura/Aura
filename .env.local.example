# ── Aura — copy to .env.local and fill in your values ────────────────────────

# WalletConnect / Reown Project ID  (required for wallet modal)
# Get one free at: https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chain profile — "testnet" uses Celo Sepolia + Base Sepolia, "mainnet" uses Celo + Base
NEXT_PUBLIC_CHAIN_PROFILE=testnet

# App display name (shown in wallet modal)
NEXT_PUBLIC_APP_NAME=Aura

# ── Contract addresses (set after deploying AuraTip.sol) ─────────────────────
NEXT_PUBLIC_AURA_TIP_ADDRESS_TESTNET=
NEXT_PUBLIC_AURA_TIP_ADDRESS_MAINNET=
# MockUSDm address on Celo Sepolia testnet (output of contracts:deploy:testnet)
NEXT_PUBLIC_USDM_ADDRESS_TESTNET=
# Base chain contract addresses (set after deploying to Base)
NEXT_PUBLIC_AURA_TIP_ADDRESS_BASE_MAINNET=
NEXT_PUBLIC_AURA_TIP_ADDRESS_BASE_SEPOLIA=

# ── AI Scout (optional — falls back to heuristic if unset) ───────────────────
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── CeloScan API key (AI Scout, frontend reads — Celoscan HTTP API) ───────────
# Get one free at: https://celoscan.io/myapikey
NEXT_PUBLIC_CELOSCAN_API_KEY=

# ── Etherscan.io API key (Hardhat verify + AI Scout — API V2 multichain) ─────
# One key covers ALL chains: Celo (42220), Base (8453), Celo Sepolia, Base Sepolia.
# Get one free at: https://etherscan.io/apidashboard
ETHERSCAN_API_KEY=

# ── RPC provider (Hardhat deploy + frontend fallback) ────────────────────────
# Free at: https://dashboard.alchemy.com → Create App
# Enable Celo Mainnet, Celo Sepolia, Base Mainnet, and Base Sepolia in the Networks tab
# One Alchemy key covers all chains: base-mainnet.g.alchemy.com/v2/{key}, etc.
ALCHEMY_API_KEY=

# ── Deployer wallet (server-side only — NEVER prefix with NEXT_PUBLIC_) ───────
# Private key of the wallet used to deploy contracts (funded with CELO for gas)
DEPLOYER_PRIVATE_KEY=
